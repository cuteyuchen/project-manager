{
    "pluginName": "项目管理器",
    "version": "1.0.3",
    "description": "Project Manager for frontend developers",
    "author": "Your Name",
    "homepage": "https://github.com/cuteyuchen/project-manager",
    "main": "index.html",
    "preload": "preload.js",
    "logo": "logo.png",
    "features": [
        {
            "code": "main",
            "explain": "项目管理器",
            "cmds": [
                "项目管理器",
                "Project Manager",
                "project-manager",
                "pm"
            ],
            "windowType": "system"
        },
        {
            "code": "import_project",
            "explain": "导入前端项目",
            "cmds": [
                {
                    "type": "files",
                    "label": "导入项目",
                    "fileType": "directory",
                    "match": "/.*/",
                    "minLength": 1
                }
            ],
            "windowType": "system"
        }
    ]
}
