{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Project Manager",
  "version": "1.5.3",
  "identifier": "com.cuteyuchen.project-manager",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Project Manager",
        "width": 1120,
        "height": 730,
        "minWidth": 1120,
        "minHeight": 680,
        "decorations": false
      },
      {
        "label": "quick-search",
        "title": "Project Search",
        "url": "index.html?window=quick-search",
        "width": 680,
        "height": 460,
        "center": true,
        "visible": false,
        "focus": false,
        "decorations": false,
        "resizable": false,
        "maximizable": false,
        "minimizable": false,
        "closable": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "app",
      "dmg",
      "deb",
      "appimage"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "languages": [
          "English",
          "SimpChinese"
        ]
      }
    }
  }
}
